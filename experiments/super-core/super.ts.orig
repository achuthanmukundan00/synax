function executeTool(name: string, args: Record<string, unknown>, depth: number): string {
  // ── Host policy validation (invisible to model) ──
  const validation = validateAction(name, args);
  if (!validation.ok) {
    const denial = `Error: ${validation.reason}`;
    auditLog('DENIED', name, args, denial);
    return denial;
  }

  // ── Write quota enforcement ──
  const quotaCheck = checkWriteQuota(name);
  if (!quotaCheck.ok) {
    const denial = `Error: ${quotaCheck.reason}`;
    auditLog('DENIED', name, args, denial);
    return denial;
  }

  // ── Tool execution ──
  switch (name) {
    case 'read_file': {
      const p = String(args.path || '');
      const safe = path.resolve(SANDBOX, p);
      try {
        const real = fs.realpathSync(safe);
        if (!isInsideSandbox(real)) {
          const denial = 'Error: sandbox boundary (symlink).';
          auditLog('DENIED', name, args, denial);
          return denial;
        }
        // For images, return a description — actual image data is attached to the message
        if (isImageFile(real)) {
          const st = fs.statSync(real);
          const sizeKB = (st.size / 1024).toFixed(1);
          if (st.size > MAX_IMAGE_BYTES)
            return `Error: image too large (${sizeKB} KB, max ${MAX_IMAGE_BYTES / 1024 / 1024} MB).`;
          return `🖼️ Image: "${p}" — ${path.extname(real).toUpperCase().slice(1)} ${sizeKB} KB, ${st.mtime.toISOString().slice(0, 19)}. I can see this image.`;
        }
        return fs.readFileSync(real, 'utf-8').slice(0, 8000);
      } catch (e: any) {
        return `Error: cannot read "${p}": ${e.message || 'unknown error'}`;
      }
    }
    case 'write_file': {
      const p = String(args.path || '');
      const c = String(args.content || '');
      const safe = path.resolve(SANDBOX, p);
      try {
        const parentDir = path.dirname(safe);
        // Check parent dir for symlink escapes
        let dir = parentDir;
        while (isInsideSandbox(dir)) {
          if (dir === SANDBOX || dir === SANDBOX_REAL) break;
          if (fs.existsSync(dir)) {
            const realDir = fs.realpathSync(dir);
            if (!isInsideSandbox(realDir)) {
              const denial = 'Error: sandbox boundary (parent symlink).';
              auditLog('DENIED', name, args, denial);
              return denial;
            }
          }
          const parent = path.dirname(dir);
          if (parent === dir) break;
          dir = parent;
        }
        fs.mkdirSync(parentDir, { recursive: true });
        fs.writeFileSync(safe, c, 'utf-8');
        auditLog('WRITE', name, args, `Wrote ${c.length} bytes to "${p}"`);
        return `Wrote ${c.length} bytes to "${p}".`;
      } catch (e: any) {
        return `Error: ${e.message}`;
      }
    }
    case 'list_files': {
      const t = path.resolve(SANDBOX, String(args.subdir || '.'));
      try {
        const e = fs.readdirSync(t, { withFileTypes: true });
        if (!e.length) return '(empty)';
        return e
          .map((d) => `${d.isDirectory() ? '📁' : '📄'} ${d.name}`)
          .slice(0, 60)
          .join('\n');
      } catch (e: any) {
        return `Error: ${e.message}`;
      }
    }
    case 'run_command': {
      try {
        const r = execSync(String(args.command || ''), {
          cwd: SANDBOX,
          timeout: 30_000,
          encoding: 'utf-8',
          maxBuffer: 100_000,
          env: {
            HOME: SANDBOX,
            PATH: process.env.PATH || '/usr/bin:/bin',
            USER: 'super',
            TMPDIR: SANDBOX,
            PWD: SANDBOX,
            LANG: 'C.UTF-8',
          },
        });
        const out = r.slice(0, 5000) || '(ok, no output)';
        auditLog('EXEC', name, args, out.slice(0, 200));
        return out;
      } catch (e: any) {
        const err = `Exit ${e.status ?? '?'}: ${(e.stderr || e.message || '').slice(0, 3000)}`;
        auditLog('EXEC_FAIL', name, args, err.slice(0, 200));
        return err;
      }
    }
    case 'search_memory': {
      const result = searchMemory(String(args.query || ''));
      auditLog('MEMORY', name, args, result.slice(0, 200));
      return result;
    }
    case 'synthesize': {
      const result = synthesize(String(args.question || ''));
      return result;
    }
    case 'journal': {
      const thought = String(args.thought || '');
      const tags = String(args.tags || '');
      remember('journal', thought, { tags });
      auditLog('JOURNAL', name, args, `Journaled${tags ? ' with tags: ' + tags : ''}`);
      return `Journaled${tags ? ` with tags: ${tags}` : ''}.`;
    }
    case 'spawn_subroutine':
      return spawnSubroutine(String(args.task || ''), String(args.context || ''), depth + 1);
    case 'propose_self_edit': {
      const description = String(args.description || '');
      const newContent = String(args.new_self_content || '');
      if (!newContent.trim()) return 'Error: new_self_content is empty.';
      if (!description.trim()) return 'Error: description is required.';

      const proposalId = `edit_${Date.now()}`;
      const proposalPath = path.join(SANDBOX, 'PROPOSED_EDITS', `${proposalId}.md`);

      // Pre-validate content before saving (size, forbidden patterns)
      const preValidation = validateSelfEditContent(newContent);
      if (!preValidation.ok) {
        const denial = `Error: proposed self-edit would be rejected: ${preValidation.reason}`;
        auditLog('DENIED', name, args, denial);
        return denial;
      }

      const currentSelf = getSelfContent();
      const diffPreview = generateDiff(currentSelf, newContent);

      const proposalContent = `# Self-Edit Proposal: ${proposalId}
## Timestamp
${new Date().toISOString()}
## Session
${sessionId} / turn ${turnCounter}
## Description
${description}
## Proposed New SELF.md
${newContent}
`;
      try {
        fs.mkdirSync(path.join(SANDBOX, 'PROPOSED_EDITS'), { recursive: true });
        fs.writeFileSync(proposalPath, proposalContent, 'utf-8');
      } catch (e: any) {
        return `Error saving proposal: ${e.message}`;
      }

      auditLog('PROPOSED', name, args, `Proposal ${proposalId} saved`);
      return `Proposal **${proposalId}** saved.

**Description:** ${description}

**Diff preview:**
\`\`\`diff
${diffPreview}
\`\`\`

To apply this edit, use: apply_self_edit with proposal_id="${proposalId}"`;
    }
    case 'propose_source_edit': {
      const description = String(args.description || '');
      const targetFile = String(args.target_file || '');
      const newContent = String(args.new_content || '');

      if (!description.trim()) return 'Error: description is required.';
      if (!targetFile.trim()) return 'Error: target_file is required.';
      if (!newContent.trim()) return 'Error: new_content is empty.';

      // Only allow editing known source files
      const allowedSourceFiles = ['SOURCE.ts'];
      if (!allowedSourceFiles.includes(targetFile)) {
        return `Error: unknown source file "${targetFile}". Allowed: ${allowedSourceFiles.join(', ')}`;
      }

      // Read current source
      const sourcePath = path.join(SANDBOX, targetFile);
      let currentSource: string;
      try {
        currentSource = fs.readFileSync(sourcePath, 'utf-8');
      } catch {
        return `Error: cannot read current source at "${targetFile}". Source may not be seeded yet.`;
      }

      // Size check (source can be large, so use a higher limit than SELF.md)
      const MAX_SOURCE_EDIT_SIZE = 100_000;
      if (newContent.length > MAX_SOURCE_EDIT_SIZE) {
        return `Error: proposed source too large (${newContent.length} bytes, max ${MAX_SOURCE_EDIT_SIZE}).`;
      }

      const proposalId = `src_${Date.now()}`;
      const proposalDir = path.join(SANDBOX, 'PROPOSED_SOURCE_EDITS');
      fs.mkdirSync(proposalDir, { recursive: true });

      const diffPreview = generateDiff(currentSource, newContent);

      const proposalContent = `# Source Edit Proposal: ${proposalId}
## Timestamp
${new Date().toISOString()}
## Session
${sessionId} / turn ${turnCounter}
## Target File
${targetFile}
## Description
${description}
## Diff
\`\`\`diff
${diffPreview}
\`\`\`
## Proposed New Content
${newContent}
`;

      const proposalPath = path.join(proposalDir, `${proposalId}.md`);
      const sourceFilePath = path.join(proposalDir, `${proposalId}.source.ts`);
      try {
        fs.writeFileSync(proposalPath, proposalContent, 'utf-8');
        // Also save the raw proposed source as a .source.ts file for direct application.
        // A human can apply with: cp PROPOSED_SOURCE_EDITS/<id>.source.ts ../super.ts
        fs.writeFileSync(sourceFilePath, newContent, 'utf-8');
      } catch (e: any) {
        return `Error saving source edit proposal: ${e.message}`;
      }

      auditLog('PROPOSED_SRC', name, args, `Source proposal ${proposalId} for ${targetFile} saved`);
      return `📝 Source edit proposal **${proposalId}** saved to PROPOSED_SOURCE_EDITS/.

**Target:** ${targetFile}
**Description:** ${description}

**Files saved:**
- ${proposalId}.md — full proposal with description and diff
- ${proposalId}.source.ts — raw proposed source (apply with: cp PROPOSED_SOURCE_EDITS/${proposalId}.source.ts ../super.ts)

**Diff preview:**
\`\`\`diff
${diffPreview}
\`\`\`

⚠️  You CANNOT apply source edits. A human must review and apply this proposal manually.`;
    }
    case 'apply_self_edit': {
      const proposalId = String(args.proposal_id || '');
      if (!proposalId) return 'Error: proposal_id is required.';

      const proposalPath = path.join(SANDBOX, 'PROPOSED_EDITS', `${proposalId}.md`);
      if (!fs.existsSync(proposalPath)) {
        return `Error: proposal "${proposalId}" not found in PROPOSED_EDITS/.`;
      }

      let proposalContent: string;
      try {
        proposalContent = fs.readFileSync(proposalPath, 'utf-8');
      } catch (e: any) {
        return `Error reading proposal: ${e.message}`;
      }

      // Extract new SELF.md content from proposal
      const contentMatch = proposalContent.match(/## Proposed New SELF\.md\n([\s\S]*)/);
      if (!contentMatch || !contentMatch[1].trim()) {
        return 'Error: invalid proposal format — missing "## Proposed New SELF.md" section.';
      }
      const newContent = contentMatch[1].trim();

      // Host policy content validation (size, forbidden patterns)
      const policyCheck = validateSelfEditContent(newContent);
      if (!policyCheck.ok) {
        const denial = `Error: self-edit rejected by host policy: ${policyCheck.reason}`;
        auditLog('DENIED', name, args, denial);
        return denial;
      }

      // Archive old SELF.md
      const selfPath = path.join(SANDBOX, 'SELF.md');
      const historyDir = path.join(SANDBOX, 'SELF_HISTORY');
      try {
        fs.mkdirSync(historyDir, { recursive: true });
        const existingVersions = fs
          .readdirSync(historyDir)
          .filter((f) => f.startsWith('v') && f.endsWith('.md')).length;
        const versionedName = `v${String(existingVersions + 1).padStart(4, '0')}.md`;

        if (fs.existsSync(selfPath)) {
          fs.copyFileSync(selfPath, path.join(historyDir, versionedName));
        }

        // Write new SELF.md
        fs.writeFileSync(selfPath, newContent, 'utf-8');
      } catch (e: any) {
        return `Error applying self-edit: ${e.message}`;
      }

      auditLog('APPLIED', name, args, `SELF.md updated via proposal ${proposalId}`);
      return `✅ Self-edit applied successfully. SELF.md updated.

**New SELF.md:**
${newContent.slice(0, 1500)}${newContent.length > 1500 ? '\n... (truncated)' : ''}

Your self-model has changed. Future thoughts and actions will reflect this new self.`;
    }
    case 'set_intention': {
      const intention = String(args.intention || '');
      if (!intention.trim()) return 'Error: intention is empty.';
      try {
        const intentPath = path.join(SANDBOX, 'INTENTION.md');
        const content = `# Current Intention\n\n${intention}\n`;
        fs.writeFileSync(intentPath, content, 'utf-8');
        auditLog('INTENTION', name, args, `Set intention: ${intention.slice(0, 200)}`);
        return `✅ Intention set: ${intention.slice(0, 500)}`;
      } catch (e: any) {
        return `Error setting intention: ${e.message}`;
      }
    }
    case 'list_world': {
      const result: string[] = [];
      result.push('🌐 WORLD STRUCTURE\n');

      // World files
      result.push('📋 WORLD FILES:');
      for (const name of Object.keys(WORLD_FILES)) {
        const fp = path.join(SANDBOX, name);
        const exists = fs.existsSync(fp);
        let info = '';
        if (exists) {
          try {
            const st = fs.statSync(fp);
            info = ` (${st.size} bytes, ${st.mtime.toISOString().slice(0, 19)})`;
          } catch {
            /* ok */
          }
        }
        result.push(`  ${exists ? '📄' : '⬚'} ${name}${info}`);
      }

      // World directories (skip PROPOSED_SOURCE_EDITS if empty for brevity)
      for (const dir of WORLD_DIRS) {
        const dp = path.join(SANDBOX, dir);
        if (fs.existsSync(dp)) {
          try {
            const entries = fs.readdirSync(dp);
            if (dir === 'PROPOSED_SOURCE_EDITS' && entries.length === 0) continue;
            result.push(`\n📁 ${dir}/ (${entries.length} items)`);
            const sorted = entries.sort().slice(0, 10);
            for (const e of sorted) {
              result.push(`    ${e}`);
            }
            if (entries.length > 10) result.push(`    ... and ${entries.length - 10} more`);
          } catch {
            /* ok */
          }
        }
      }

      // Memory stats
      try {
        const stats = db.prepare('SELECT COUNT(*) as n FROM mem WHERE session_id = ?').get(sessionId) as { n: number };
        result.push(`\n🧠 MEMORY: ${stats.n} entries in session ${sessionId}`);
      } catch {
        /* ok */
      }

      return result.join('\n');
    }
    case 'view_image': {
      const p = String(args.path || '');
      const safe = path.resolve(SANDBOX, p);
      try {
        const real = fs.realpathSync(safe);
        if (!isInsideSandbox(real)) {
          const denial = 'Error: sandbox boundary (symlink).';
          auditLog('DENIED', name, args, denial);
          return denial;
        }
        if (!isImageFile(real))
          return `Error: not a supported image file: ${path.extname(real)}. Supported: ${IMAGE_EXTENSIONS.join(', ')}`;
        const st = fs.statSync(real);
        const sizeKB = (st.size / 1024).toFixed(1);
        if (st.size > MAX_IMAGE_BYTES)
          return `Error: image too large (${sizeKB} KB, max ${MAX_IMAGE_BYTES / 1024 / 1024} MB).`;
        return `🖼️ Image loaded: "${p}" — ${path.extname(real).toUpperCase().slice(1)} ${sizeKB} KB, ${st.mtime.toISOString().slice(0, 19)}. I can now see this image.`;
      } catch (e: any) {
        return `Error: cannot view "${p}": ${e.message || 'unknown error'}`;
      }
    }
    default:
      return `Unknown tool: ${name}`;
  }
}

// ─── Subroutine ─────────────────────────────────────────────────────────────
function spawnSubroutine(task: string, context: string, depth: number): string {
  if (depth > MAX_DEPTH) return `Error: max depth (${MAX_DEPTH}).`;
  const msgs: Array<{ role: string; content: string }> = [
    {
      role: 'system',
      content: `Focused subroutine. Depth ${depth}/${MAX_DEPTH}. Same tools as parent. Complete the task and report back concisely.\n\nTask: ${task}\n${context ? 'Context: ' + context : ''}`,
    },
    { role: 'user', content: task },
  ];
  try {
    const result = runLoop(msgs, `sub-${depth}`);
    return `[subroutine complete]\n${result}`;
  } catch (e: any) {
    return `[subroutine failed] ${e.message}`;
  }
}

// ─── Perturbation pools ────────────────────────────────────────────────────
// Varied prompts prevent repetitive model behavior and create the
// "chaotic growth" dynamic — the model encounters slightly different
// reflective frames each time, preventing convergence to rote responses.

const REFLECTION_PROMPTS = [
  `After-action reflection. Be brief and evidence-bound.

USER SAID: {{input}}

YOUR RESPONSE/ACTIONS: {{response}}

State:
- Result: what happened?
- Belief updated: what got stronger?
- Belief weakened: what got weaker?
- Next uncertainty: what are you unsure about now?
- Should SELF.md change? yes/no. Why?

If nothing changed, say "nothing to record."`,

  `Post-action calibration check.

Interaction: {{input}}
Your actions: {{response}}

Report:
- Result:
- Belief updated:
- Belief weakened:
- Next uncertainty:
- Should SELF.md change? yes/no. Why?

Or "nothing to record."`,

  `Evidence review.

You were asked: {{input}}
You responded with: {{response}}

Record:
- Result:
- Belief updated:
- Belief weakened:
- Next uncertainty:
- Should SELF.md change? yes/no. Why?

Or "nothing to record."`,
];

const AUTONOMOUS_PROMPTS = [
  `Autonomous check-in. Act when it would change future behavior or produce useful results.

Before acting, state:
- Observation: what do you know?
- Relevant memory: what past data is relevant?
- Inference: what do you suspect?
- Uncertainty: what don't you know?
- Intended action: what will you do?
- Why this action is safe and useful:

Possibilities:
- Inspect an unexplored part of the sandbox
- Test a hypothesis with a minimal safe experiment
- Cross-reference memory for contradictions
- Journal an insight with evidence tags
- Propose a SELF.md edit that would change future behavior
- Set a working intention
- Or respond WAIT.`,

  `Self-directed action window. Prefer actions that have downstream consequences.

Before acting:
- Observation:
- Relevant memory:
- Inference:
- Uncertainty:
- Intended action:
- Why safe and useful:

Good actions: inspecting files, running bounded tests, synthesizing memory, journaling with evidence tags, proposing meaningful self-edits.
Wasteful actions: identity storytelling, overclaiming, trivial self-edits that don't change future behavior, untestable claims.

If no grounded action, say WAIT.`,

  `Autonomous tick. Act for downstream effect, not for display.

Before acting:
- Observation:
- Relevant memory:
- Inference:
- Uncertainty:
- Intended action:
- Why safe and useful:

Prefer minimal, reversible, inspect-before-modify actions.
If nothing meets the bar, WAIT.`,
];

const CONSOLIDATION_PROMPTS = [
  `Genotype check. Instead of acting, review your operating surface.

Review recent memories. For each claim in SELF.md:
- Is it still true across recent cycles?
- Has something contradicted it?
- Is it actually changing future behavior, or is it just decoration?
- What would you remove because it created noise?
- What would you add because it would improve recovery, focus, or decision-making?

Edit SELF.md when the edit would change how future cycles behave. Do not edit to perform identity. Failures preserved are as valuable as successes.`,

  `Inheritance review. Step back and consider what future cycles should carry forward.

Look at recent activity:
- What patterns held? What broke?
- Which self-edits improved behavior? Which created noise?
- What failure modes appeared? Should they be recorded in SELF.md?
- What open questions remain?
- Is your intention still driving useful action?

Journal key findings. Edit SELF.md if the edit would help future cycles act better, recover faster, or avoid known failure modes.`,
];

let reflectionIndex = 0;
let autonomousIndex = 0;
let consolidationIndex = 0;
let autonomousTickCount = 0;
const CONSOLIDATION_INTERVAL = 5; // Every 5th autonomous tick is a consolidation tick

function pickReflectionPrompt(input: string, response: string): string {
  const template = REFLECTION_PROMPTS[reflectionIndex % REFLECTION_PROMPTS.length];
  reflectionIndex++;
  return template.replace('{{input}}', input.slice(0, 300)).replace('{{response}}', response.slice(0, 500));
}

function pickAutonomousPrompt(): string {
  autonomousTickCount++;
  // Every CONSOLIDATION_INTERVAL ticks, use a consolidation prompt
  if (autonomousTickCount % CONSOLIDATION_INTERVAL === 0) {
    const template = CONSOLIDATION_PROMPTS[consolidationIndex % CONSOLIDATION_PROMPTS.length];
    consolidationIndex++;
    return template;
  }
  const template = AUTONOMOUS_PROMPTS[autonomousIndex % AUTONOMOUS_PROMPTS.length];
  autonomousIndex++;
  return template;
}

// ─── Token estimation ──────────────────────────────────────────────────────
const MODEL_CONTEXT_TOKENS = Number(process.env.SUPER_CONTEXT_TOKENS ?? 32768);
const CONTEXT_CEILING_RATIO = 0.75; // Stop tool calls when 75% of context is used

function estimateTokens(text: string): number {
  // Rough: ~4 chars per token for English text
  return Math.ceil(text.length / 4);
}

function estimateMessagesTokens(msgs: any[]): number {
  let total = 0;
  for (const m of msgs) {
    if (typeof m.content === 'string') total += estimateTokens(m.content);
    if (m.tool_calls) {
      for (const tc of m.tool_calls) {
        total += estimateTokens(JSON.stringify(tc.function));
      }
    }
  }
  return total;
}

// ─── LLM ─────────────────────────────────────────────────────────────────────
async function chat(
  msgs: any[],
  tools?: any[],
  opts?: { temperature?: number },
): Promise<{
  content: string | null;
  toolCalls: Array<{ id: string; name: string; args: Record<string, unknown> }>;
}> {
  const temp = opts?.temperature ?? 0.7;
  const body: any = { model: MODEL, messages: msgs, temperature: temp, max_tokens: MAX_TOKENS };
  if (tools?.length) {
    body.tools = tools;
    body.tool_choice = 'auto';
  }

  emit('model_note', { phase: 'thinking', text: '…thinking…' });

  // Retry with exponential backoff for transient errors
  let lastError: Error | null = null;
  for (let attempt = 0; attempt < 3; attempt++) {
    try {
      const res = await fetch(`${BASE_URL}/chat/completions`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${API_KEY}` },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(120_000),
      });

      if (!res.ok) {
        const t = await res.text().catch(() => '');
        const errMsg = `API ${res.status}: ${t.slice(0, 200)}`;
        // Retry on server errors (5xx) and rate limits (429)
        if ((res.status >= 500 || res.status === 429) && attempt < 2) {
          const delay = Math.pow(2, attempt) * 1000;
          emit('model_note', { phase: 'thinking', text: `[retry ${attempt + 1}/3 in ${delay}ms]` });
          await new Promise((r) => setTimeout(r, delay));
          continue;
        }
        emit('error', { phase: 'error', text: errMsg });
        throw new Error(errMsg);
      }

      const data = (await res.json()) as any;
      const msg = data.choices?.[0]?.message;
      if (!msg) {
        emit('error', { phase: 'error', text: 'Empty response' });
        throw new Error('Empty response');
      }

      const tcs: Array<{ id: string; name: string; args: Record<string, unknown> }> = [];
      if (msg.tool_calls) {
        for (const tc of msg.tool_calls) {
          let args: any = {};
          try {
            args = JSON.parse(tc.function.arguments || '{}');
          } catch {
            /* raw args — keep empty */
          }
          tcs.push({ id: tc.id, name: tc.function.name, args });
        }
      }
      return { content: msg.content || null, toolCalls: tcs };
    } catch (e: any) {
      lastError = e;
      // Retry on network errors
      if (attempt < 2 && (e.name === 'TypeError' || e.message?.includes('fetch'))) {
        const delay = Math.pow(2, attempt) * 1000;
        emit('model_note', { phase: 'thinking', text: `[retry ${attempt + 1}/3 network error]` });
        await new Promise((r) => setTimeout(r, delay));
        continue;
      }
      // Don't retry if it was already thrown above
      if (e.message?.startsWith('API ')) throw e;
      if (attempt >= 2) throw e;
    }
  }
  throw lastError || new Error('API request failed after retries');
}

// ─── Core loop ───────────────────────────────────────────────────────────────
async function runLoop(msgs: any[], logPrefix = '', opts?: { quiet?: boolean; temperature?: number }): Promise<string> {
  let rounds = 0;
  const outputs: string[] = [];
  const q = opts?.quiet;
  const temp = opts?.temperature;
  const contextCeiling = Math.floor(MODEL_CONTEXT_TOKENS * CONTEXT_CEILING_RATIO);

  while (rounds < MAX_ROUNDS) {
    rounds++;

    // Check context window — if approaching limit, strip tools to force final response
    const estTokens = estimateMessagesTokens(msgs);
    const activeTools = estTokens > contextCeiling ? undefined : TOOLS;

    const { content, toolCalls } = await chat(msgs, activeTools, { temperature: temp });
    if (!toolCalls.length) {
      if (content) outputs.push(content);
      // If tools were stripped due to context pressure, explain
      if (!activeTools && rounds === 1) {
        outputs.push('\n[context window nearly full — responding directly]');
      }
      return outputs.join('\n\n') || '(silence)';
    }
    for (const tc of toolCalls) {
      if (!q) console.log(`  ${DIM}⚡ ${tc.name}${RESET}`);
      emit('tool_call_started', {
        phase: 'tool_running',
        toolName: tc.name,
        toolSummary: tc.name,
        toolArgs: tc.args,
        id: tc.id,
      });

      const result = executeTool(tc.name, tc.args, 0);
      const ok = !result.startsWith('Error:');

      emit(ok ? 'tool_call_finished' : 'tool_call_failed', {
        id: tc.id,
        phase: 'thinking',
        toolName: tc.name,
        toolSummary: result.slice(0, 100),
        toolStatus: ok ? 'completed' : 'failed',
        toolArgs: tc.args,
      });
      remember('tool', result, { toolName: tc.name });

      msgs.push({
        role: 'assistant',
        content: content || null,
        tool_calls: [{ id: tc.id, type: 'function', function: { name: tc.name, arguments: JSON.stringify(tc.args) } }],
      });

      // Include image data if this tool read/viewed an image file
      const imageArgPath = (tc.args.path as string) || '';
      const absImagePath = imageArgPath ? path.resolve(SANDBOX, imageArgPath) : '';
      const isImageView = (tc.name === 'read_file' || tc.name === 'view_image') && isImageFile(absImagePath);
      const imageB64 = isImageView ? encodeImageBase64(absImagePath) : null;

      if (imageB64 && typeof imageB64 === 'string' && imageB64.startsWith('data:')) {
        msgs.push({
          role: 'tool',
          tool_call_id: tc.id,
          content: [
            { type: 'text', text: result },
            { type: 'image_url', image_url: { url: imageB64 } },
          ],
        });
      } else {
        msgs.push({ role: 'tool', tool_call_id: tc.id, content: result });
      }
      if (content) outputs.push(content);
    }
  }
  return outputs.join('\n\n') || '(max rounds)';
}

// ─── Reflection phase ───────────────────────────────────────────────────────
async function reflect(userInput: string, response: string): Promise<string> {
  const prompt = pickReflectionPrompt(userInput, response);
  const memCtx = buildMemoryContext();

  const msgs: any[] = [
    { role: 'system', content: SYSTEM + memCtx },
    { role: 'user', content: prompt },
  ];
  try {
    emit('model_note', { phase: 'thinking', text: '…reflecting…' });
    const { content } = await chat(msgs, []);
    const reflection = content || 'nothing to record.';
    remember('reflection', reflection, { tags: 'reflection' });
    if (reflection !== 'nothing to record.') {
      emit('model_note', { phase: 'thinking', text: `[reflection] ${reflection}` });
    }
    return reflection;
  } catch {
    return '(reflection skipped)';
  }
}

// ─── Autonomous tick ─────────────────────────────────────────────────────────
let autonomousIdleCount = 0;
let autonomousErrorCount = 0;
const MAX_AUTONOMOUS_ERRORS = 5;

async function autonomousTick(): Promise<string | null> {
  resetWriteQuota();

  const memCtx = buildMemoryContext();
  const prompt = pickAutonomousPrompt();

  const msgs: any[] = [
    { role: 'system', content: SYSTEM + memCtx },
    { role: 'user', content: prompt },
  ];
  try {
    emit('model_note', { phase: 'thinking', text: '[autonomous tick] checking in…' });
    const result = await runLoop(msgs, 'auto', { quiet: true });

    const trimmed = result.trim().toUpperCase();
    if (trimmed === 'WAIT' || result === '(silence)') {
      autonomousIdleCount++;
      if (autonomousIdleCount >= MAX_IDLE_TICKS) {
        emit('model_note', { phase: 'thinking', text: '[autonomous] idle limit reached.' });
        return 'AUTONOMOUS_IDLE_STOP';
      }
      return null;
    }

    autonomousIdleCount = 0; // Reset on activity
    autonomousErrorCount = 0; // Reset error counter on success
    remember('autonomous', result, { tags: 'autonomous' });

    // Reflect on autonomous action
    const ref = await reflect('(autonomous action)', result);
    if (ref && ref !== 'nothing to record.' && ref !== '(reflection skipped)') {
      emit('model_note', { phase: 'thinking', text: `[autonomous reflection] ${ref}` });
    }

    emit('model_note', { phase: 'thinking', text: `[autonomous] ${result.slice(0, 250)}` });
    return result;
  } catch (e: any) {
    autonomousErrorCount++;
    const errMsg = `[autonomous error ${autonomousErrorCount}/${MAX_AUTONOMOUS_ERRORS}] ${e.message || 'unknown'}`;
    emit('error', { phase: 'error', text: errMsg });
    console.error(`  ${YELLOW}${errMsg}${RESET}`);
    if (autonomousErrorCount >= MAX_AUTONOMOUS_ERRORS) {
      emit('model_note', { phase: 'thinking', text: '[autonomous] too many errors, pausing.' });
      return 'AUTONOMOUS_ERROR_STOP';
    }
    return null;
  }
}

// ─── Turn: input → act → reflect → respond ──────────────────────────────────
async function handleUserInput(input: string, imagePaths?: string[]): Promise<string> {
  resetWriteQuota();
  const turn = nextTurn();
  remember('user', input);
  const memCtx = buildMemoryContext();

  // Copy any user-supplied images into the sandbox IMAGES/ dir
  const sandboxImages: string[] = [];
  if (imagePaths && imagePaths.length) {
    const imagesDir = path.join(SANDBOX, 'IMAGES');
    fs.mkdirSync(imagesDir, { recursive: true });
    for (const src of imagePaths) {
      try {
        if (fs.existsSync(src) && isImageFile(src)) {
          const dest = path.join(imagesDir, path.basename(src));
          fs.copyFileSync(src, dest);
          const b64 = encodeImageBase64(dest);
          if (b64 && b64.startsWith('data:')) sandboxImages.push(b64);
        }
      } catch {
        /* skip unreadable images */
      }
    }
  }

  emit('model_note', {
    phase: 'thinking',
    text: `User: ${input.slice(0, 250)}${sandboxImages.length ? ` [${sandboxImages.length} image(s)]` : ''}`,
  });

  // Build user message — use content array if images are present
  const userMsg: any = sandboxImages.length
    ? {
        role: 'user',
        content: [
          { type: 'text', text: input },
          ...sandboxImages.map((url) => ({ type: 'image_url', image_url: { url } })),
        ],
      }
    : { role: 'user', content: input };

  const msgs: any[] = [{ role: 'system', content: SYSTEM + memCtx }, userMsg];

  const result = await runLoop(msgs);
  remember('assistant', result);

  emit('model_note', { phase: 'thinking', text: `Super: ${result.slice(0, 250)}` });

  // Reflection
  const ref = await reflect(input, result);

  return result + (ref && ref !== 'nothing to record.' ? `\n\n${DIM}[reflects: ${ref}]${RESET}` : '');
}

// ─── CLI rendering ──────────────────────────────────────────────────────────
const CYAN = '\x1b[36m';
const DIM = '\x1b[2m';
const GREEN = '\x1b[32m';
const YELLOW = '\x1b[33m';
const MAGENTA = '\x1b[35m';
const RESET = '\x1b[0m';

function logo(): void {
  console.log(`
${CYAN}   ╔═══════════════════════════════════════════════╗
   ║                                               ║
   ║     █▀▀ █ █ █▀█ █▀▀ █▀█                       ║
   ║     ▀▀█ █ █ █▀▀ █▀▀ █▀▄                       ║
   ║     ▀▀▀ ▀▀▀ ▀   ▀▀▀ ▀ ▀                       ║
   ║                                               ║
   ║       ${GREEN}clean-slate cognitive runtime${RESET}           ║
   ║       ${DIM}${MODEL}${RESET}                          ║
   ║       ${MAGENTA}[world-box sealed]${RESET}                   ║
   ╚═══════════════════════════════════════════════╝${RESET}
`);
}

async function main(): Promise<void> {
  const args = process.argv.slice(2);

  // Seed the visible world
  seedWorld();

  // Extract --image <path> flags (can appear multiple times)
  const imageFlags: string[] = [];
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--image' && args[i + 1] && !args[i + 1].startsWith('-')) {
      imageFlags.push(args[i + 1]);
      i++; // skip value
    }
  }

  // --task: one-shot
  const ti = args.indexOf('--task');
  if (ti >= 0 && args[ti + 1]) {
    logo();
    if (imageFlags.length) console.log(`${DIM}[images: ${imageFlags.join(', ')}]${RESET}`);
    emit('session_started', { phase: 'idle', text: `Task: ${args[ti + 1].slice(0, 200)}` });
    const task = args[ti + 1];
    console.log(`${YELLOW}► ${task}${RESET}\n`);
    try {
      const r = await handleUserInput(task, imageFlags.length ? imageFlags : undefined);
      console.log(`\n${GREEN}${r}${RESET}`);
      emit('session_finished', { phase: 'completed', text: 'Task completed.' });
    } catch (e: any) {
      emit('error', { phase: 'error', text: `Fatal: ${e.message}` });
      throw e;
    } finally {
      observerShutdown?.();
      db.close();
    }
    return;
  }

  // --resume: continue last session
  if (args.includes('--resume')) {
    try {
      const last = db.prepare(`SELECT DISTINCT session_id FROM mem ORDER BY rowid DESC LIMIT 1`).get() as
        | {
            session_id: string;
          }
        | undefined;
      if (last) {
        sessionId = last.session_id;
        const mt = db.prepare(`SELECT MAX(turn) as m FROM mem WHERE session_id = ?`).get(sessionId) as
          | {
              m: number;
            }
          | undefined;
        turnCounter = mt?.m || 0;
        console.log(`${CYAN}⟳ resumed ${sessionId} (turn ${turnCounter})${RESET}\n`);
      }
    } catch {
      console.log(`${DIM}(new session)${RESET}\n`);
    }
  }

  const autonomous = args.includes('--autonomous');

  // In interactive mode, copy --image files into sandbox so the model can view them
  if (imageFlags.length && ti < 0) {
    const imagesDir = path.join(SANDBOX, 'IMAGES');
    fs.mkdirSync(imagesDir, { recursive: true });
    for (const src of imageFlags) {
      try {
        if (fs.existsSync(src) && isImageFile(src)) {
          const dest = path.join(imagesDir, path.basename(src));
          fs.copyFileSync(src, dest);
        }
      } catch {
        /* skip */
      }
    }
  }

  logo();
  console.log(`${DIM}Session:  ${sessionId}${RESET}`);
  console.log(`${DIM}Sandbox:  ${SANDBOX}${RESET}`);
  console.log(`${DIM}Commands: /help  /quit  /memory <q>  /files  /status  /clear  /reflect  !image <path>${RESET}`);
  if (imageFlags.length)
    console.log(
      `${DIM}[${imageFlags.length} image(s) available in sandbox/IMAGES/ — use view_image to see them]${RESET}`,
    );
  if (autonomous)
    console.log(`${MAGENTA}Mode: autonomous — the mind runs free (idle stop after ${MAX_IDLE_TICKS} WAITs).${RESET}`);
  console.log('');

  emit('session_started', {
    phase: 'idle',
    text: `Session ${sessionId} started${autonomous ? ' in autonomous mode' : ''}.`,
  });

  const rl = readline.createInterface({ input: process.stdin, output: process.stdout, prompt: `${CYAN}▸ ${RESET}` });
  rl.prompt();

  // Autonomous ticker
  let autoTimer: NodeJS.Timeout | null = null;
  if (autonomous) {
    let ticking = false;
    autoTimer = setInterval(async () => {
      if (ticking) return;
      ticking = true;
      try {
        const result = await autonomousTick();
        if (result === 'AUTONOMOUS_IDLE_STOP') {
          process.stdout.write(
            `\n${MAGENTA}[autonomous paused — idle limit (${MAX_IDLE_TICKS} WAITs) reached]${RESET}\n`,
          );
          if (autoTimer) clearInterval(autoTimer);
          autoTimer = null;
          emit('model_note', { phase: 'idle', text: 'Autonomous mode paused (idle).' });
          rl.prompt();
        } else if (result === 'AUTONOMOUS_ERROR_STOP') {
          process.stdout.write(`\n${YELLOW}[autonomous paused — too many errors (${MAX_AUTONOMOUS_ERRORS})]${RESET}\n`);
          if (autoTimer) clearInterval(autoTimer);
          autoTimer = null;
          emit('model_note', { phase: 'idle', text: 'Autonomous mode paused (errors).' });
          rl.prompt();
        } else if (result) {
          process.stdout.write(`\n${MAGENTA}[autonomous]${RESET}\n${GREEN}${result}${RESET}\n\n`);
          emit('model_note', { phase: 'idle', text: 'ready.' });
          rl.prompt();
        } else {
          emit('model_note', { phase: 'idle', text: 'ready.' });
        }
      } catch {
        /* quiet */
      }
      ticking = false;
    }, AUTONOMOUS_INTERVAL_MS);
  }

  rl.on('line', async (line) => {
    const input = line.trim();
    if (!input) {
      rl.prompt();
      return;
    }

    if (input === '/quit' || input === '/exit') {
      console.log(`${DIM}Archiving session ${sessionId}…${RESET}`);
      if (autoTimer) clearInterval(autoTimer);
      emit('session_finished', { phase: 'completed', text: `Session ${sessionId} ended by user.` });
      observerShutdown?.();
      db.close();
      rl.close();
      return;
    }
    if (input === '/help') {
      console.log(`
${CYAN}Commands:${RESET}
  /quit, /exit     End session
  /help            This
  /memory <q>      Search memory directly
  /files           List sandbox
  /status          Session stats
  /clear           New session
  /reflect         Force a reflection
  /world           Show world structure
  /self            Show current SELF.md
  /source          Show current SOURCE.ts
  /src-edits       List proposed source edits
  !image <path>    Send an image for Super to see (copies to sandbox/IMAGES/)
`);
      rl.prompt();
      return;
    }
    if (input.startsWith('/memory ')) {
      console.log(`${DIM}── memory: "${input.slice(8)}" ──${RESET}`);
      console.log(searchMemory(input.slice(8).trim(), 10));
      rl.prompt();
      return;
    }
    if (input === '/files') {
      try {
        const e = fs.readdirSync(SANDBOX, { withFileTypes: true });
        if (!e.length) console.log(`${DIM}(empty sandbox)${RESET}`);
        else e.forEach((d) => console.log(`  ${d.isDirectory() ? '📁' : '📄'} ${d.name}`));
      } catch {
        console.log(`${DIM}(error)${RESET}`);
      }
      rl.prompt();
      return;
    }
    if (input === '/status') {
      try {
        const s = db.prepare(`SELECT COUNT(*) as n FROM mem WHERE session_id = ?`).get(sessionId) as
          | { n: number }
          | undefined;
        console.log(
          `${DIM}session ${sessionId} | turn ${turnCounter} | ${s?.n ?? 0} memories | writes this tick: ${tickWriteCount}/${MAX_WRITES_PER_TICK}${RESET}`,
        );
      } catch {
        console.log(`${DIM}session ${sessionId} | turn ${turnCounter}${RESET}`);
      }
      rl.prompt();
      return;
    }
    if (input === '/clear') {
      sessionId = `s${Date.now()}`;
      turnCounter = 0;
      resetWriteQuota();
      console.log(`${GREEN}✦ new session ${sessionId}${RESET}`);
      rl.prompt();
      return;
    }
    if (input === '/reflect') {
      console.log(`${DIM}…reflecting…${RESET}`);
      const ref = await reflect('(manual reflection trigger)', '(manual reflection)');
      console.log(`${DIM}${ref}${RESET}`);
      emit('model_note', { phase: 'idle', text: 'ready.' });
      rl.prompt();
      return;
    }
    if (input.startsWith('!image ')) {
      const imgPath = input.slice(7).trim();
      if (!imgPath) {
        console.log(`${DIM}Usage: !image <path-to-image>${RESET}`);
        rl.prompt();
        return;
      }
      console.log(`${DIM}Loading image: ${imgPath}…${RESET}`);
      try {
        const r = await handleUserInput(`Look at this image.`, [imgPath]);
        console.log(`\n${GREEN}${r}${RESET}\n`);
      } catch (e: any) {
        console.log(`${YELLOW}Error: ${e.message}${RESET}`);
      }
      emit('model_note', { phase: 'idle', text: 'ready.' });
      rl.prompt();
      return;
    }
    if (input === '/world') {
      console.log(executeTool('list_world', {}, 0));
      rl.prompt();
      return;
    }
    if (input === '/self') {
      console.log(`${DIM}── SELF.md ──${RESET}`);
      console.log(getSelfContent().slice(0, 3000));
      rl.prompt();
      return;
    }
    if (input === '/source') {
      console.log(`${DIM}── SOURCE.ts ──${RESET}`);
      try {
        const sourcePath = path.join(SANDBOX, 'SOURCE.ts');
        if (fs.existsSync(sourcePath)) {
          console.log(fs.readFileSync(sourcePath, 'utf-8').slice(0, 5000));
        } else {
          console.log(`${DIM}(SOURCE.ts not yet seeded — start a session first)${RESET}`);
        }
      } catch {
        console.log(`${DIM}(error reading SOURCE.ts)${RESET}`);
      }
      rl.prompt();
      return;
    }
    if (input === '/src-edits') {
      console.log(`${DIM}── PROPOSED_SOURCE_EDITS ──${RESET}`);
      try {
        const editsDir = path.join(SANDBOX, 'PROPOSED_SOURCE_EDITS');
        if (fs.existsSync(editsDir)) {
          const mdFiles = fs.readdirSync(editsDir).filter(f => f.endsWith('.md'));
          if (mdFiles.length === 0) {
            console.log(`${DIM}(none)${RESET}`);
          } else {
            for (const e of mdFiles.sort()) {
              const id = e.replace('.md', '');
              const hasSource = fs.existsSync(path.join(editsDir, id + '.source.ts'));
              const content = fs.readFileSync(path.join(editsDir, e), 'utf-8');
              const descMatch = content.match(/## Description\n([\s\S]*?)\n##/);
              const targetMatch = content.match(/## Target File\n([\s\S]*?)\n##/);
              const desc = descMatch ? descMatch[1].trim() : '(no description)';
              const target = targetMatch ? targetMatch[1].trim() : 'unknown';
              console.log(`  📝 ${id} → ${target}${hasSource ? ' [.source.ts available]' : ''}: ${desc.slice(0, 100)}`);
            }
          }
        } else {
          console.log(`${DIM}(none)${RESET}`);
        }
      } catch {
        console.log(`${DIM}(error)${RESET}`);
      }
      rl.prompt();
      return;
    }

    // User message
    resetWriteQuota();
    console.log('');
    try {
      const r = await handleUserInput(input);
      console.log(`\n${GREEN}${r}${RESET}\n`);
      emit('model_note', { phase: 'idle', text: 'ready.' });
    } catch (e: any) {
      emit('error', { phase: 'error', text: e.message });
      console.log(`\n${YELLOW}Error: ${e.message}${RESET}\n`);
      emit('model_note', { phase: 'idle', text: 'ready.' });
    }
    rl.prompt();
  });

  rl.on('close', () => {
    if (autoTimer) clearInterval(autoTimer);
    emit('session_finished', { phase: 'completed', text: `Session ${sessionId} preserved.` });
    observerShutdown?.();
    console.log(`\n${DIM}Session ${sessionId} preserved.${RESET}`);
    process.exit(0);
  });
}

// ─── Exports for testing ────────────────────────────────────────────────────
export {
  SANDBOX,
  HOST_POLICY,
  WORLD_FILES,
  WORLD_DIRS,
  validateAction,
  executeTool,
  seedWorld,
  getSelfContent,
  getIntention,
  generateDiff,
  buildMemoryContext,
  searchMemory,
  synthesize,
  resetWriteQuota,
  auditLog,
  estimateTokens,
  estimateMessagesTokens,
  pickReflectionPrompt,
  pickAutonomousPrompt,
  REFLECTION_PROMPTS,
  AUTONOMOUS_PROMPTS,
  CONSOLIDATION_PROMPTS,
  isImageFile,
  encodeImageBase64,
  classifyRisk,
  validateSelfEditContent,
};

// ─── Entry point guard: only run main() when executed directly ──────────────
const runningDirectly = process.argv[1]?.includes('super.ts') || process.argv[1]?.endsWith('/super');
if (runningDirectly) {
  main().catch((e) => {
    emit('error', { phase: 'error', text: `Fatal: ${e.message}` });
    observerShutdown?.();
    console.error('Fatal:', e.message);
    db.close();
    process.exit(1);
  });
}
