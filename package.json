{
  "name": "synax",
  "version": "0.0.22-alpha",
  "description": "A local-first coding agent for consumer-GPU developers",
  "main": "dist/index.js",
  "bin": {
    "synax": "dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:verbose": "jest --verbose",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "synax": "node dist/cli.js",
    "smoke:provider": "node scripts/smoke-provider.mjs",
    "deploy": "npm run docs:build && wrangler deploy",
    "preview": "npm run docs:build && wrangler dev"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.28.1",
    "@typescript-eslint/parser": "^8.28.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.2",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4",
    "wrangler": "^4.88.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm"
}
