{
  "name": "synax",
  "version": "0.2.0-alpha.1",
  "description": "A local-first coding agent for consumer-GPU developers",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "require": "./dist/events/index.js",
      "default": "./dist/events/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "require": "./dist/skills/index.js",
      "default": "./dist/skills/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "require": "./dist/tools/index.js",
      "default": "./dist/tools/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "require": "./dist/llm/index.js",
      "default": "./dist/llm/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "require": "./dist/memory/index.js",
      "default": "./dist/memory/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "require": "./dist/session/index.js",
      "default": "./dist/session/index.js"
    }
  },
  "bin": {
    "synax": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "preinstall": "bun -e \"const agent = (process.env.npm_config_user_agent || ''); if (!agent.startsWith('bun/')) { console.error('╔══════════════════════════════════════╗\\n║  This project requires bun.          ║\\n║  The TUI will not work with npm.     ║\\n║  Run: bun install                    ║\\n╚══════════════════════════════════════╝'); process.exit(1); }\"",
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "verify": "bun run typecheck && bun run lint && bun run format:check && bun run build && bun run test",
    "test": "jest",
    "test:verbose": "jest --verbose",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "synax": "bun dist/cli.js",
    "bench": "bash scripts/bench-synax.sh",
    "smoke:provider": "bun scripts/smoke-provider.mjs",
    "deploy": "vitepress build docs && wrangler deploy",
    "preview": "vitepress build docs && wrangler dev",
    "verify:pack": "bash scripts/verify-pack.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@opentui/core": "^0.2.10",
    "commander": "^14.0.0",
    "toml": "^3.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.28.1",
    "@typescript-eslint/parser": "^8.28.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.0.2",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4",
    "wrangler": "^4.88.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.14"
}
