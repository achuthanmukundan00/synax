# Synax project configuration
#
# Copy this file to .synax.toml and customize for your project.
# .synax.toml is gitignored — never commit secrets.
#
# Config layers (merged left-to-right, later wins):
#   built-in defaults → ~/.config/synax/config.toml → .synax.toml

# Optional: pick a visual style for chat rendering.
# Values: "model" (auto-detect), "default", "qwen", "openai", "claude", "deepseek", "gemini"
# coreVisualProfile = "model"

# ─── Active provider and model ─────────────────────────────

[active]
# Which provider to use from the [providers] section below.
provider = "relay-local"
# Model ID (must match one listed under that provider).
model = "Qwen3.6-35B-A3B-UD-IQ3_XXS.gguf"
# Thinking level: "off", "low", "medium", "high", or "auto".
# Only takes effect when the model declares supports_thinking = true.
thinking = "off"

# ─── Provider definitions ──────────────────────────────────

# --- Relay (local llama.cpp / Ollama / OpenAI-compatible) ---
[providers.relay-local]
enabled = true
name = "Relay Local"
compatibility = "openai-compatible"
base_url = "http://127.0.0.1:1234/v1"

[[providers.relay-local.models]]
id = "Qwen3.6-35B-A3B-UD-IQ3_XXS.gguf"
display_name = "Qwen3.6 35B Local"
context_window = 131072
supports_thinking = false

# --- DeepSeek ---
[providers.deepseek]
enabled = false
name = "DeepSeek"
compatibility = "openai-compatible"
base_url = "https://api.deepseek.com/v1"
api_key_env = "DEEPSEEK_API_KEY"

[[providers.deepseek.models]]
id = "deepseek-v4-pro"
display_name = "DeepSeek V4 Pro"
context_window = 1000000
supports_thinking = true
thinking_levels = ["off", "high", "xhigh"]
default_thinking = "high"

[[providers.deepseek.models]]
id = "deepseek-v4-flash"
display_name = "DeepSeek V4 Flash"
context_window = 1000000
supports_thinking = false

# --- OpenAI ---
[providers.openai]
enabled = false
name = "OpenAI"
compatibility = "openai-compatible"
base_url = "https://api.openai.com/v1"
api_key_env = "OPENAI_API_KEY"

[[providers.openai.models]]
id = "gpt-4o"
display_name = "GPT-4o"
context_window = 128000
supports_thinking = false

[[providers.openai.models]]
id = "o3-mini"
display_name = "o3-mini"
context_window = 200000
supports_thinking = true
thinking_levels = ["off", "low", "medium", "high"]
default_thinking = "medium"

# --- Anthropic ---
[providers.anthropic]
enabled = false
name = "Anthropic"
compatibility = "anthropic-compatible"
base_url = "https://api.anthropic.com/v1"
api_key_env = "ANTHROPIC_API_KEY"

[[providers.anthropic.models]]
id = "claude-sonnet-4-20250514"
display_name = "Claude Sonnet 4"
context_window = 200000
supports_thinking = true
thinking_levels = ["off", "low", "medium", "high"]
default_thinking = "off"

[[providers.anthropic.models]]
id = "claude-3-5-haiku-20241022"
display_name = "Claude 3.5 Haiku"
context_window = 200000
supports_thinking = false

# --- Custom OpenAI-compatible endpoint ---
# Uncomment and edit for an alternative local or hosted endpoint.
#
# [providers.custom]
# enabled = true
# name = "Custom"
# compatibility = "openai-compatible"
# base_url = "http://127.0.0.1:8080/v1"
# api_key_env = "CUSTOM_API_KEY"   # optional; omit for no-auth endpoints
#
# [[providers.custom.models]]
# id = "my-local-model"
# display_name = "My Local Model"
# context_window = 131072
# supports_thinking = false

# -- Custom headers (per provider) --
# Add arbitrary headers to provider requests:
#
# [providers.relay-local.headers]
# "X-Example" = "value"

# ─── Skills ─────────────────────────────────────────────────

# [skills]
# enabled = ["my-skill"]
# disabled = ["another-skill"]

# ─── MCP servers ───────────────────────────────────────────

# [mcp.servers.my-server]
# enabled = true
# command = "my-mcp-binary"
# args = ["--arg1", "--arg2"]
#
# [mcp.servers.my-server.env]
# "MY_ENV_VAR" = "value"
